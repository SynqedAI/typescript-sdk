{
    "compilerOptions": {
      "target": "ES2020",
      "module": "ESNext",
      "moduleResolution": "Bundler",
  
      "strict": true,
      "noUncheckedIndexedAccess": true,
  
      "declaration": true,
      "declarationMap": true,
  
      "sourceMap": true,
  
      "isolatedModules": true,
      "verbatimModuleSyntax": true,
  
      "skipLibCheck": true,
      
      "types": ["node"],
  
      "outDir": "dist"
    },
    "include": ["src", "tests"]
  }